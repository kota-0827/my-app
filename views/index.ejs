<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>ユーザー一覧</title></head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <li>
        <strong><%= user.name %></strong> 
        <!-- 年齢があれば表示し、なければ「年齢未設定」と出すぞ -->
        （<%= user.age ? user.age + ' 歳' : '年齢未設定' %>）
      </li>
    <% }) %>
  </ul>

  <h2>ユーザー追加</h2>
  <form action="/users" method="post">
    <div>
      <input type="text" name="name" placeholder="ユーザー名を入力" required>
    </div>
    <div style="margin-top: 10px;">
      <!-- ここに年齢の入力欄を追加したぞ！ name="age" が大事じゃ -->
      <input type="number" name="age" placeholder="年齢を入力">
    </div>
    <button type="submit" style="margin-top: 10px;">追加</button>
  </form>
</body>
</html>
